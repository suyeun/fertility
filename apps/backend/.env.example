PORT=3001

# JWT
JWT_SECRET=your_super_secret_key_change_this
JWT_EXPIRES_IN=7d

# Firebase Admin (서비스 계정 JSON 경로 또는 환경변수)
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_CLIENT_EMAIL=your_client_email
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Anthropic Claude
ANTHROPIC_API_KEY=your_anthropic_api_key

# RevenueCat 웹훅 시크릿 (대시보드 → Webhooks → Authorization Header)
REVENUECAT_WEBHOOK_SECRET=your_revenuecat_webhook_secret

# Cloud Scheduler 내부 호출용 시크릿
SCHEDULER_SECRET=your_scheduler_secret
