{
  "expo": {
    "name": "BOM",
    "slug": "bom-fertility",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#fff8f9"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.fertility.bom",
      "buildNumber": "1"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#fff8f9"
      },
      "package": "com.fertility.bom",
      "versionCode": 1
    },
    "plugins": [
      "expo-router",
      "expo-notifications"
    ],
    "scheme": "bom",
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "a2538b36-5ab0-45ee-8322-48ed08cf1be9"
      }
    },
    "owner": "suyeonkim"
  }
}
